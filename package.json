{
  "name": "asset-3d-viewer",
  "version": "0.1.0",
  "description": "快速瀏覽本機 3D 素材庫的小工具",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c cyan,green \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env ELECTRON_DEV=1 electron .",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.local.asset3dviewer",
    "productName": "3D 素材瀏覽器",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.0",
    "wait-on": "^8.0.1"
  }
}
